{
  "$schema": "https://opencode.ai/config.json",

  "autoupdate": true,

  "formatter": {
    "eslint": {
      "command": ["bunx", "eslint", "--fix", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".html",
        ".htm",
        ".css",
        ".scss",
        ".sass",
        ".less",
        ".vue",
        ".svelte",
        ".json",
        ".jsonc",
        ".yaml",
        ".yml",
        ".toml",
        ".xml",
        ".md",
        ".mdx",
        ".graphql",
        ".gql"
      ]
    }
  },

  "lsp": {
    "sorbet": {
      "command": ["bundle", "exec", "srb", "tc", "--lsp", "--disable-watchman"],
      "extensions": [".rb", ".rbi"]
    },
    "ruby-lsp": { "disabled": true }
  },

  "mcp": {
    "linear": {
      "type": "local",
      "command": ["npx", "mcp-remote", "https://mcp.linear.app/mcp"],
    },
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "redirectUri": "http://localhost:3118/callback",
      },
    },
  },

  "permission": {
    "task": {
      "review": "deny",
      "pr": "deny",
    },
    "linear_*": "deny",
    "slack_*": "deny",
  },


  "references": {
    "dashboard": {
      "repository": "github.com/fintoc-com/dashboard",
    },
    "fintoc-rails": {
      "repository": "github.com/fintoc-com/fintoc-rails",
    },
    "pacioli": {
      "repository": "github.com/fintoc-com/pacioli",
    },
  },

  "plugin": [
    "opencode-claude-auth@latest",
    "@daleal/opencode-workflows@0.1.3",
  ],

  "provider": {
    "openrouter": {
      "models": {
        "z-ai/glm-5.2": {
          "options": {
            "provider": {
              "order": ["fireworks", "friendli"],
              "allow_fallbacks": false,
            },
          },
        },
      },
    },
  },
}
